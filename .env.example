# Sistemas Sierra POS
SIERRA_API_URL=https://demo-services-alternative.sierraerp.com
SIERRA_API_KEY=CxzKRteOXeAr5fpa1D2wOm4tlMs64Jsz6wPoYQye8Kdz6sgZ9r0w9JOh3JbJZmlV

# Sistemas Sierra - Valores por defecto de la orden enviada al aceptar (POST /api/v1/orders)
# Tipo de orden según origen (catálogo de Sierra)
SIERRA_ORDER_TYPE=ORDEN WEB ONLINE
# Tipo de venta: clave NUMÉRICA del catálogo (GET /api/v1/tables/salestype)
SIERRA_ORDER_SALES_TYPE=1
# "0" = la cuenta se cierra automáticamente, "1" = el cliente debe cerrarla
SIERRA_ORDER_OPEN_STATUS=0
# Mesero/empleado al que se asigna la orden (clave de empleado, opcional)
SIERRA_ORDER_SERVER=
# Cajero (opcional)
SIERRA_ORDER_CASHIER=
# Enviar productos a cocina/barra (true/false)
SIERRA_ORDER_ROUTE_PRODUCTS=true
# Marcar como producción (true) o demo/pruebas (false)
SIERRA_ORDER_PRODUCTION=false
# Etiqueta del método de pago a mostrar en el PDV
SIERRA_ORDER_PAYMENT_LABEL=Uber Eats

# Webhook
WEBHOOK_SIGNATURE_SECRET=your-webhook-secret-key

# Logging
LOG_LEVEL=debug
